<?xml version="1.0" encoding="utf-8"?>
<!--
    In-app logomark: same "P" geometry as ic_launcher_foreground, scaled to a 24-unit
    viewport so it renders crisply at the TopAppBar size (~32 dp). White by default but
    tintable — used inside Compose `Icon`, which auto-tints to LocalContentColor so the
    mark adapts to dark/light mode without a separate asset.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">
    <path
        android:pathData="M 8,17.3 L 8,7.6 L 13.3,7.6 C 16,7.6 17.3,9.3 17.3,10.7 C 17.3,12 16,13.8 13.3,13.8 L 8,13.8"
        android:strokeColor="#FFFFFFFF"
        android:strokeWidth="2.9"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:fillColor="#00000000" />
</vector>
