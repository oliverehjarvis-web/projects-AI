<?xml version="1.0" encoding="utf-8"?>
<!--
    "Projects AI" monogram — a bold rounded-stroke "P" centered in the adaptive-icon safe
    area (the central 66×66 dp window of the 108×108 viewport). Stroke-based rather than
    filled so the geometry stays clean at every launcher density and the same path can be
    reused at smaller sizes for the in-app logo.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <path
        android:pathData="M 36,78 L 36,34 L 60,34 C 72,34 78,42 78,48 C 78,54 72,62 60,62 L 36,62"
        android:strokeColor="#FFFFFFFF"
        android:strokeWidth="13"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:fillColor="#00000000" />
</vector>
